# Fill values after copying from .env.example. Never commit real secrets.

NOTIFY_TARGET_USER_ID=
TELEGRAM_BOT_TOKEN=

AGENT_LLM_API_KEY=
AGENT_LLM_BASE_URL=https://api.openai.com/v1
AGENT_LLM_MODEL=gpt-5.4
# AGENT_LLM_BASE_URL=http://host.docker.internal:11434/v1
# AGENT_LLM_MODEL=qwen2.5:1.5b
# AGENT_LLM_API_KEY=local-ollama

AGENT_TELEGRAM_VOICE_ENABLED=0
# Cloud STT API key for Telegram voice transcription.
AGENT_TELEGRAM_STT_API_KEY=
# Cloud STT endpoint for audio transcription.
AGENT_TELEGRAM_STT_URL=https://api.openai.com/v1/audio/transcriptions
# Cloud STT model name.
AGENT_TELEGRAM_STT_MODEL=gpt-4o-mini-transcribe

AGENT_LLM_TIMEOUT_SEC=600
AGENT_LLM_MAX_RETRIES=2
AGENT_TELEGRAM_ENABLED=1
AGENT_TELEGRAM_STARTUP_SUMMARY=1
AGENT_RECEIPT_FORMATTER=template

OPENCLAW_IMAGE_VIA_SCRIPT=0
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=blaifa/InternVL3_5:8B
OPENCLAW_LOCAL_VISION_TIMEOUT_SEC=240
