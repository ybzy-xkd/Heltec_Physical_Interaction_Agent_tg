  "main": "index.js",
  "scripts": {
    "start": "nodemon",
    "dev": "npx cross-env NODE_ENV=dev node dist/index",
    "start-docker": "npm run clean && npx cross-env NODE_ENV=docker node dist/index",
    "clean": "rm -rf dist",
    "build:tsc": "npm run clean && npx tsc",
    "push": "git add . && git commit -m \"~\" && git push",
    "dockerInPm2": "npm i && npx tsc && npx pm2-runtime start pm2-docker.json",
    "docker": "npm ci && npx cross-env NODE_ENV=docker node dist/index",
    "test": "npx cross-env NODE_ENV=test node dist/test",
    "eval:nlu": "npx ts-node --transpile-only src/eval/runNluEval.ts",
    "eval:automation:interval-multi": "npx ts-node --transpile-only src/eval/runAutomationIntervalMultiActionEval.ts",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down"
  },
