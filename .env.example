# Copy this file to .env before running. Docker Compose loads it via env_file.

# Comma-separated Telegram user IDs allowed to use the bot and receive notifications.
# Supports one or multiple users. Do NOT wrap with quotes.
# Example (single): NOTIFY_TARGET_USER_ID=8297833475
# Example (multiple): NOTIFY_TARGET_USER_ID=8297833475,8163387137,123456789
NOTIFY_TARGET_USER_ID=
# Telegram bot token used by both notification sender and agent bot.
TELEGRAM_BOT_TOKEN=
# Primary LLM API key (OpenAI-compatible).
AGENT_LLM_API_KEY=

# OpenAI-compatible base URL for chat completions.
AGENT_LLM_BASE_URL=https://api.openai.com/v1
# Default model for planner/responder calls.
AGENT_LLM_MODEL=gpt-4o-mini
# Per-request timeout for LLM calls in seconds.
AGENT_LLM_TIMEOUT_SEC=20
# Retry attempts for retryable LLM failures (timeout, 429, 5xx).
AGENT_LLM_MAX_RETRIES=2
# Receipt formatter mode: template (fast, deterministic) | llm (slower, naturalized).
AGENT_RECEIPT_FORMATTER=template
# Timeout (seconds) for building planner device context. Default 15.
PLANNER_DEVICE_CONTEXT_TIMEOUT_SEC=15
# Max retries for planner device context build (0 or 1). Default 1.
PLANNER_DEVICE_CONTEXT_MAX_RETRIES=1
# Enable or disable Telegram agent bot listener (1/0, true/false).
AGENT_TELEGRAM_ENABLED=1
# Send startup device summary to allowlisted users on boot (1/0, true/false).
AGENT_TELEGRAM_STARTUP_SUMMARY=1
# Optional agent-only Telegram token override (falls back to TELEGRAM_BOT_TOKEN).
# AGENT_TELEGRAM_BOT_TOKEN=

# Enable local image script pipeline (1) or default chat/vision path (0).
OPENCLAW_IMAGE_VIA_SCRIPT=0
# Ollama host reachable from runtime/container.
OLLAMA_HOST=http://host.docker.internal:11434
# Local vision model name available in Ollama (exact model tag in `ollama list`).
# Example: OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_MODEL=
# Local image script timeout in seconds.
OPENCLAW_LOCAL_VISION_TIMEOUT_SEC=240

# Optional facial tuning.
# FACIAL_THRESHOLD: face match threshold (lower = stricter).
# FACIAL_TIMEOUT_SEC: per-job timeout for facial pipeline.
# FACIAL_DEBUG: verbose debug logs (1/0).
# FACIAL_QUEUE_CONCURRENCY: concurrent facial jobs.
# FACIAL_QUEUE_MAX_PENDING: max queued jobs before reject.
# FACIAL_RECOGNITION_ENABLED: feature switch (1/0).
# FACIAL_ALERT_NOTIFY_MODE: facial push mode.
# - 0: push only when non-target person is detected
# - 1: push only when target person is detected (default)
# FACIAL_THRESHOLD=0.42
# FACIAL_TIMEOUT_SEC=180
# FACIAL_DEBUG=0
# FACIAL_QUEUE_CONCURRENCY=1
# FACIAL_QUEUE_MAX_PENDING=
# FACIAL_RECOGNITION_ENABLED=1
# FACIAL_ALERT_NOTIFY_MODE=1

# IoT write / intent tuning.
# IOT_WRITE_TIMEOUT_SEC: HTTP write timeout to device (seconds).
# IOT_READ_STATUS_TIMEOUT_SEC: HTTP timeout for device /status reads (seconds). Default 15.
# IOT_SUMMARY_STATUS_TIMEOUT_SEC: per-device timeout when refreshing status for planner/device summary (seconds). Default 5.
# IOT_WRITE_VERIFY_RETRY_TIMES: retry count for post-write verification.
# IOT_WRITE_VERIFY_RETRY_INTERVAL_MS: delay between verification retries.
# IOT_INTENT_STRICT: strict intent mode switch (true/false).
# IOT_WRITE_TIMEOUT_SEC=120
# IOT_READ_STATUS_TIMEOUT_SEC=150
# IOT_SUMMARY_STATUS_TIMEOUT_SEC=15
# IOT_WRITE_VERIFY_RETRY_TIMES=2
# IOT_WRITE_VERIFY_RETRY_INTERVAL_MS=350
# IOT_INTENT_STRICT=false
