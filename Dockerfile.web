FROM node:20

WORKDIR /app

# Install python runtime/deps once at build-time (avoid fragile runtime apt/pip).
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-venv \
    python3-pip \
    python3-requests \
    build-essential \
  && rm -rf /var/lib/apt/lists/*

# Prepare dedicated python env for facial recognition dependencies.
RUN python3 -m venv /opt/pyenv
COPY script/facial_recognition/requirements.txt /tmp/facial-requirements.txt
RUN /opt/pyenv/bin/pip install --no-cache-dir -r /tmp/facial-requirements.txt

# Reduce onnxruntime C++ log noise and warm up buffalo_l at build-time to avoid first-request timeouts.
ENV ORT_LOG_SEVERITY_LEVEL=3 \
    ONNXRUNTIME_LOG_SEVERITY_LEVEL=3
RUN /opt/pyenv/bin/python -c "\
from insightface.app import FaceAnalysis;\
app = FaceAnalysis(name='buffalo_l');\
app.prepare(ctx_id=-1, det_size=(640, 640));\
print('insightface buffalo_l warmup ok')\
"

